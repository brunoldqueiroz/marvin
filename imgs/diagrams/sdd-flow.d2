direction: down

title: Marvin SDD — Spec-Driven Development Flow {
  style: {
    font-size: 28
    bold: true
    fill: transparent
    stroke: transparent
  }
}

# --- Phase 0: Constitution ---
constitution: "/sdd-constitution" {
  style: {
    fill: "#fff3e0"
    stroke: "#e65100"
    border-radius: 8
    font-size: 18
    bold: true
  }
}

constitution_detail: |md
  Primeiro uso por projeto.
  Captura princípios inegociáveis:
  stack, testes, qualidade, segurança.
| {
  style: {
    fill: "#fff8e1"
    stroke: "#ffb300"
    border-radius: 4
    font-size: 12
  }
}

constitution_out: ".specify/memory/constitution.md" {
  shape: page
  style: {
    fill: "#fff3e0"
    stroke: "#e65100"
  }
}

constitution -> constitution_detail: "" {style.stroke-dash: 3}
constitution -> constitution_out: escreve

# --- Phase 1: Specify ---
specify: "/sdd-specify" {
  style: {
    fill: "#e3f2fd"
    stroke: "#1565c0"
    border-radius: 8
    font-size: 18
    bold: true
  }
}

specify_steps: {
  style: {
    fill: "#e8eaf6"
    stroke: "#3949ab"
    border-radius: 8
  }

  read_const: Lê constitution.md {
    shape: oval
    style.fill: "#fff3e0"
  }
  clarify: Faz perguntas ao usuário {
    shape: diamond
    style.fill: "#fce4ec"
  }
  has_unknowns: Incógnitas? {
    shape: diamond
    style.fill: "#fce4ec"
  }
  researcher: Agente Researcher {
    shape: hexagon
    style.fill: "#f3e5f5"
    style.stroke: "#7b1fa2"
  }
  research_out: research.md {
    shape: page
    style.fill: "#f3e5f5"
  }

  read_const -> clarify
  clarify -> has_unknowns
  has_unknowns -> researcher: sim
  researcher -> research_out
  has_unknowns -> spec_write: não {style.stroke-dash: 3}

  spec_write: Gera spec.md {
    shape: oval
    style.fill: "#e3f2fd"
  }
  research_out -> spec_write: incorpora
}

spec_out: ".specify/specs/{id}-{slug}/spec.md" {
  shape: page
  style: {
    fill: "#e3f2fd"
    stroke: "#1565c0"
  }
}

constitution_out -> specify: contexto {style.stroke-dash: 3}
specify -> specify_steps
specify_steps -> spec_out: escreve

# --- Phase 2: Plan ---
plan: "/sdd-plan" {
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
    border-radius: 8
    font-size: 18
    bold: true
  }
}

plan_agent: Agente Plan {
  shape: hexagon
  style: {
    fill: "#c8e6c9"
    stroke: "#2e7d32"
  }
}

plan_out: ".specify/specs/{id}-{slug}/plan.md" {
  shape: page
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
  }
}

spec_out -> plan: lê spec.md
plan -> plan_agent: delega
plan_agent -> plan_out: escreve

# --- Phase 3: Tasks ---
tasks: "/sdd-tasks" {
  style: {
    fill: "#fce4ec"
    stroke: "#c62828"
    border-radius: 8
    font-size: 18
    bold: true
  }
}

tasks_out: ".specify/specs/{id}-{slug}/tasks.md" {
  shape: page
  style: {
    fill: "#fce4ec"
    stroke: "#c62828"
  }
}

plan_out -> tasks: lê plan.md
tasks -> tasks_out: escreve

# --- Phase 4: Implementation (Marvin orchestrates) ---
implement: "Implementação" {
  style: {
    fill: "#ede7f6"
    stroke: "#4527a0"
    border-radius: 8
    font-size: 18
    bold: true
  }
}

marvin_orchestration: Marvin Orquestra {
  style: {
    fill: "#f5f5f5"
    stroke: "#616161"
    border-radius: 8
  }

  detect: Detecta tasks.md {
    shape: oval
    style.fill: "#ede7f6"
  }
  load_ctx: Carrega spec + plan + tasks {
    shape: oval
    style.fill: "#ede7f6"
  }

  implementer: Agente Implementer {
    shape: hexagon
    style.fill: "#c8e6c9"
    style.stroke: "#2e7d32"
  }
  reviewer: Agente Reviewer {
    shape: hexagon
    style.fill: "#fff9c4"
    style.stroke: "#f9a825"
  }
  tester: Agente Tester {
    shape: hexagon
    style.fill: "#ffccbc"
    style.stroke: "#d84315"
  }

  done: Feature pronta {
    shape: oval
    style: {
      fill: "#c8e6c9"
      stroke: "#2e7d32"
      bold: true
    }
  }

  detect -> load_ctx
  load_ctx -> implementer: delega
  implementer -> reviewer: code review
  reviewer -> tester: testes
  tester -> done: aprovado
}

tasks_out -> implement: "usuário pede implementação"
implement -> marvin_orchestration: "rules/specs.md instrui"

# --- Legend ---
legend: Legenda {
  style: {
    fill: "#fafafa"
    stroke: "#bdbdbd"
    border-radius: 8
  }

  grid-columns: 2

  skill_icon: Skill (slash command) {
    style.fill: "#e3f2fd"
    style.border-radius: 8
  }
  agent_icon: Agente especialista {
    shape: hexagon
    style.fill: "#f3e5f5"
  }
  file_icon: Artefato (.md) {
    shape: page
    style.fill: "#e8f5e9"
  }
  decision_icon: Decisão / Interação {
    shape: diamond
    style.fill: "#fce4ec"
  }
}
